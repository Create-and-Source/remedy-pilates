# ── Wearable API Credentials ────────────────────────────────────────────
# Client-side (VITE_ prefix — safe to expose, identifies your app)
VITE_FITBIT_CLIENT_ID=
VITE_WHOOP_CLIENT_ID=
VITE_OURA_CLIENT_ID=
VITE_GARMIN_CONSUMER_KEY=

# Server-side only (Vercel env vars — NEVER exposed to browser)
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=

# ── How to get API credentials ──────────────────────────────────────────
# Fitbit:  https://dev.fitbit.com/apps → Register a new app
#          Type: "Server", Callback URL: https://your-domain.vercel.app/admin/wearables
#
# WHOOP:   https://developer.whoop.com → Create an application
#          Redirect URI: https://your-domain.vercel.app/admin/wearables
#
# Oura:    https://cloud.ouraring.com/v2/docs → Create an application
#          Redirect URI: https://your-domain.vercel.app/admin/wearables
#
# Garmin:  https://developer.garmin.com/gc-developer-program/
#          Requires business partnership for Health API access
#
# ── Apple Watch (via Terra API) ─────────────────────────────────────────
# Terra provides a unified API bridge to Apple Health (HealthKit).
# Sign up at https://tryterra.co → Dashboard → API Keys
TERRA_DEV_ID=
TERRA_API_KEY=
#
# Apple Watch also supports offline import via Health app export:
# Settings → Health → Export All Health Data → upload .zip in Wearables Hub
